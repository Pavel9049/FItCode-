# =============================================================================
# FitCoach Bot - Конфигурация окружения
# =============================================================================

# =============================================================================
# ОСНОВНЫЕ НАСТРОЙКИ БОТА
# =============================================================================

# Токен Telegram бота (получите у @BotFather)
TELEGRAM_BOT_TOKEN=8269244638:AAHbZ8O3eJ6dt-SRmsdnP_bQ9XTn0zxScY

# Режим работы: polling (для разработки) или webhook (для продакшена)
RUN_MODE=polling

# Базовый URL для webhook (только для RUN_MODE=webhook)
WEBHOOK_BASE_URL=https://your-domain.com

# Порт для веб-сервера
PORT=8080

# =============================================================================
# БАЗА ДАННЫХ
# =============================================================================

# URL базы данных
# Для SQLite (разработка):
DATABASE_URL=sqlite+aiosqlite:///dev.db

# Для PostgreSQL (продакшен):
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/fitcoach

# URL Redis (опционально, для кэширования)
REDIS_URL=redis://localhost:6379

# =============================================================================
# ПЛАТЕЖНЫЕ СИСТЕМЫ
# =============================================================================

# Stripe (международные платежи)
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ЮKassa (для РФ)
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# Тинькофф (опционально)
TINKOFF_TERMINAL_KEY=your_terminal_key_here
TINKOFF_SECRET_KEY=your_secret_key_here

# NOWPayments (криптовалюты, опционально)
NOWPAYMENTS_API_KEY=your_api_key_here

# =============================================================================
# AI И ИНТЕГРАЦИИ
# =============================================================================

# Google Vision API (для анализа фото блюд)
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/credentials.json

# =============================================================================
# АДМИНИСТРАЦИЯ
# =============================================================================

# ID администраторов (через запятую)
ADMIN_IDS=[123456789,987654321]

# ID группы поддержки (для PRO пользователей)
SUPPORT_CHAT_ID=-1001234567890

# =============================================================================
# РАССЫЛКИ И ПЛАНИРОВЩИК
# =============================================================================

# Включить планировщик рассылок
SCHEDULER_ENABLED=true

# Интервал рассылок в часах
BROADCAST_INTERVAL_HOURS=4

# =============================================================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# =============================================================================

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Максимальное количество подключений к БД
DB_POOL_SIZE=10

# Таймаут подключения к БД (секунды)
DB_CONNECT_TIMEOUT=30

# Размер пула Redis
REDIS_POOL_SIZE=10

# =============================================================================
# БЕЗОПАСНОСТЬ
# =============================================================================

# Секретный ключ для подписи webhook'ов
WEBHOOK_SECRET=your_webhook_secret_here

# Максимальное количество попыток входа
MAX_LOGIN_ATTEMPTS=5

# Время блокировки после неудачных попыток (минуты)
LOGIN_BLOCK_TIME=15

# =============================================================================
# ЛИМИТЫ И ОГРАНИЧЕНИЯ
# =============================================================================

# Максимальное количество сообщений в минуту
RATE_LIMIT_MESSAGES=30

# Максимальное количество запросов к API в минуту
RATE_LIMIT_API=100

# Максимальный размер загружаемых файлов (МБ)
MAX_FILE_SIZE=10

# =============================================================================
# УВЕДОМЛЕНИЯ
# =============================================================================

# Email для уведомлений администратора
ADMIN_EMAIL=admin@fitcoach.com

# Telegram для уведомлений администратора
ADMIN_TELEGRAM=@admin_username

# =============================================================================
# МОНИТОРИНГ
# =============================================================================

# Включить метрики
METRICS_ENABLED=true

# URL для отправки метрик (опционально)
METRICS_URL=https://metrics.your-domain.com

# =============================================================================
# РЕЗЕРВНОЕ КОПИРОВАНИЕ
# =============================================================================

# Включить автоматические бэкапы
BACKUP_ENABLED=true

# Директория для бэкапов
BACKUP_DIR=/home/bot/backups

# Количество дней хранения бэкапов
BACKUP_RETENTION_DAYS=30

# =============================================================================
# ПРИМЕРЫ НАСТРОЕК ДЛЯ РАЗНЫХ СРЕД
# =============================================================================

# =============================================================================
# РАЗРАБОТКА (development)
# =============================================================================
# RUN_MODE=polling
# DATABASE_URL=sqlite:///dev.db
# LOG_LEVEL=DEBUG
# SCHEDULER_ENABLED=false

# =============================================================================
# ТЕСТИРОВАНИЕ (testing)
# =============================================================================
# RUN_MODE=polling
# DATABASE_URL=sqlite:///test.db
# LOG_LEVEL=DEBUG
# SCHEDULER_ENABLED=false
# STRIPE_API_KEY=sk_test_...
# YOOKASSA_SHOP_ID=test_shop_id

# =============================================================================
# ПРОДАКШЕН (production)
# =============================================================================
# RUN_MODE=webhook
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/fitcoach
# REDIS_URL=redis://localhost:6379
# LOG_LEVEL=INFO
# SCHEDULER_ENABLED=true
# STRIPE_API_KEY=sk_live_...
# YOOKASSA_SHOP_ID=live_shop_id
# WEBHOOK_BASE_URL=https://your-domain.com

# =============================================================================
# ПРИМЕЧАНИЯ
# =============================================================================
# 1. Никогда не коммитьте реальные токены в git
# 2. Используйте разные токены для разработки и продакшена
# 3. Регулярно обновляйте секретные ключи
# 4. Настройте резервное копирование базы данных
# 5. Мониторьте логи и метрики
# 6. Используйте SSL сертификаты в продакшене